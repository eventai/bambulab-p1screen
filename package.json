{
  "name": "bambulab-p1screen",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite --config frontend/vite.config.ts",
    "dev:server": "tsx watch backend/src/index.ts",
    "dev:apk": "cd android && ./gradlew :app:assembleDebug",
    "lint": "npm run lint:web && npm run lint:server",
    "lint:web": "eslint \"frontend/src/**/*.{ts,vue}\"",
    "lint:server": "eslint \"backend/src/**/*.ts\"",
    "lint:apk": "cd android && ./gradlew :app:lint",
    "typecheck": "npm run typecheck:web && npm run typecheck:server",
    "typecheck:web": "vue-tsc --noEmit -p frontend/tsconfig.json",
    "typecheck:server": "tsc --noEmit -p backend/tsconfig.json",
    "prebuild": "npm run lint && npm run typecheck",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build --config frontend/vite.config.ts",
    "build:server": "tsc -p backend/tsconfig.json",
    "build:apk": "cd android && ./gradlew :app:assembleRelease",
    "start": "NODE_ENV=production node dist/server/index.js",
    "preview": "vite preview --config frontend/vite.config.ts"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.63",
    "@types/express": "^5.0.6",
    "@types/humanize-duration": "^3.27.4",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitejs/plugin-legacy": "^5.4.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "core-js": "^3.42.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.4.11",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "browserslist": [
    "android >= 5",
    "ios >= 10",
    "chrome >= 55",
    "chromeandroid >= 55"
  ]
}
